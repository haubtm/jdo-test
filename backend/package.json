{
  "name": "secure-vault-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start:dev:gateway": "nest start api-gateway --watch",
    "start:dev:auth": "nest start auth-service --watch",
    "start:dev:vault": "nest start vault-service --watch",
    "start:dev:all": "powershell -Command \"Start-Job { npm run start:dev:auth }; Start-Job { npm run start:dev:vault }; npm run start:dev:gateway\""
  },
  "dependencies": {
    "@nestjs/common": "^10.4.5",
    "@nestjs/core": "^10.4.5",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/microservices": "^10.4.5",
    "@nestjs/platform-express": "^10.4.5",
    "@nestjs/typeorm": "^11.0.0",
    "argon2": "^0.41.1",
    "dotenv": "^17.3.1",
    "mysql2": "^3.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@types/node": "^22.7.6",
    "typescript": "^5.6.3"
  }
}
